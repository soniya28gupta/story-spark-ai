{
  "name": "story-spark-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Story Spark AI",
  "license": "MIT",
  "contributors": [
    {
      "name": "Charan Balaji",
      "email": "neelamapallicharanbalaji14@gmail.com",
      "url": "https://github.com/charanbalaji2005"
    }
  ],
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npx concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "start:backend": "npm run start -w backend",
    "start:frontend": "npm run start -w frontend",
    "lint": "npm run lint -w frontend"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "react-is": "^19.2.6",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3"
  }
}
